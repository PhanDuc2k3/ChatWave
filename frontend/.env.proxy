# Dùng khi deploy lên Vercel - proxy qua Vercel, không cần HTTPS trên VPS
# Copy nội dung này vào Vercel Environment Variables

VITE_API_BASE_URL=https://chatwave.site/api-proxy/core
VITE_CHATBOT_API_URL=https://chatwave.site/api-proxy/chatbot

# Realtime (WebSocket) - Vercel KHÔNG proxy được WebSocket, tạm dùng HTTP (sẽ bị Mixed Content)
# Khi nào có SSL trên VPS mới fix được
VITE_REALTIME_URL=http://157.15.108.181:5002
