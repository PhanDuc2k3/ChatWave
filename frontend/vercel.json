{
  "rewrites": [
    {
      "source": "/api-proxy/core/:path*",
      "destination": "https://api.chatwave.site/api/v1/:path*"
    },
    {
      "source": "/api-proxy/chatbot/:path*",
      "destination": "https://chatbot.chatwave.site/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}